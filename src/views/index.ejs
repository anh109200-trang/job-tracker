<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Job Tracker Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
</head>
<body class="bg-gray-50 min-h-screen font-sans antialiased text-gray-900">

    <nav class="bg-white shadow-sm border-b sticky top-0 z-10">
        <div class="max-w-6xl mx-auto px-4 h-16 flex justify-between items-center">
            <div class="flex items-center gap-2">
                <div class="bg-blue-600 text-white p-2 rounded-lg">
                    <i class="fas fa-briefcase text-xl"></i>
                </div>
                <span class="text-xl font-bold tracking-tight text-blue-900">JobTracker<span class="text-blue-500">.io</span></span>
            </div>
            
            <% if (user) { %>
                <div class="flex items-center gap-6">
                    <div class="hidden md:block text-right">
                        <p class="text-xs text-gray-500 uppercase font-bold">Người dùng</p>
                        <p class="text-sm font-semibold text-gray-800"><%= user %></p>
                    </div>
                    <form action="/auth" method="POST">
                        <input type="hidden" name="action" value="logout">
                        <button class="flex items-center gap-2 text-sm font-bold text-red-500 hover:bg-red-50 p-2 rounded-lg transition">
                            <i class="fas fa-sign-out-alt"></i> Đăng xuất
                        </button>
                    </form>
                </div>
            <% } %>
        </div>
    </nav>

    <main class="max-w-6xl mx-auto px-4 py-8">
        <% if (!user) { %>
            <div class="max-w-md mx-auto mt-10">
                <div class="bg-white p-8 rounded-2xl shadow-xl border border-gray-100">
                    <div id="login-form">
                        <h2 class="text-2xl font-extrabold mb-6 text-gray-800">Đăng nhập hệ thống</h2>
                        <form action="/auth" method="POST" class="space-y-4">
                            <input type="hidden" name="action" value="login">
                            <div>
                                <label class="text-xs font-bold text-gray-500 uppercase mb-1 block">Tên đăng nhập</label>
                                <input type="text" name="username" class="w-full border-gray-200 border p-3 rounded-xl focus:ring-2 focus:ring-blue-500 focus:outline-none transition" required>
                            </div>
                            <div>
                                <label class="text-xs font-bold text-gray-500 uppercase mb-1 block">Mật khẩu</label>
                                <input type="password" name="password" class="w-full border-gray-200 border p-3 rounded-xl focus:ring-2 focus:ring-blue-500 focus:outline-none transition" required>
                            </div>
                            <button class="w-full bg-blue-600 hover:bg-blue-700 text-white font-bold py-3 rounded-xl shadow-lg shadow-blue-200 transition-all active:scale-95">Đăng nhập</button>
                        </form>
                        <p class="text-center mt-6 text-sm text-gray-500">Chưa có tài khoản? <a href="#" onclick="showRegister()" class="text-blue-600 font-bold hover:underline">Đăng ký ngay</a></p>
                    </div>

                    <div id="register-form" class="hidden">
                        <h2 class="text-2xl font-extrabold mb-6 text-gray-800">Tạo tài khoản mới</h2>
                        <form action="/auth" method="POST" class="space-y-4">
                            <input type="hidden" name="action" value="register">
                            <input type="text" name="username" placeholder="Tên đăng nhập" class="w-full border-gray-200 border p-3 rounded-xl focus:ring-2 focus:ring-green-500 focus:outline-none transition" required>
                            <input type="email" name="email" placeholder="Email" class="w-full border-gray-200 border p-3 rounded-xl focus:ring-2 focus:ring-green-500 focus:outline-none transition" required>
                            <input type="password" name="password" placeholder="Mật khẩu" class="w-full border-gray-200 border p-3 rounded-xl focus:ring-2 focus:ring-green-500 focus:outline-none transition" required>
                            <input type="password" name="re_password" placeholder="Nhập lại mật khẩu" class="w-full border-gray-200 border p-3 rounded-xl focus:ring-2 focus:ring-green-500 focus:outline-none transition" required>
                            <button class="w-full bg-green-600 hover:bg-green-700 text-white font-bold py-3 rounded-xl shadow-lg shadow-green-200 transition-all active:scale-95">Đăng ký</button>
                        </form>
                        <p class="text-center mt-6 text-sm text-gray-500">Đã có tài khoản? <a href="#" onclick="showLogin()" class="text-blue-600 font-bold hover:underline">Đăng nhập</a></p>
                    </div>
                </div>
            </div>
        <% } else { %>
            <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
                
                <div class="lg:col-span-1">
                    <div class="bg-white p-6 rounded-2xl shadow-sm border border-gray-100 sticky top-24">
                        <h3 class="text-lg font-bold mb-4 flex items-center gap-2">
                            <i class="fas fa-plus-circle text-blue-500"></i> Thêm Công Việc
                        </h3>
                        <form action="/jobs" method="POST" class="space-y-4">
                            <div>
                                <label class="text-xs font-bold text-gray-400 uppercase mb-1 block">Vị trí ứng tuyển</label>
                                <input type="text" name="title" placeholder="VD: React Developer" class="w-full border-gray-200 border p-3 rounded-xl focus:ring-2 focus:ring-blue-500 focus:outline-none transition" required>
                            </div>
                            <div>
                                <label class="text-xs font-bold text-gray-400 uppercase mb-1 block">Tên công ty</label>
                                <input type="text" name="company" placeholder="VD: Google, Shopee..." class="w-full border-gray-200 border p-3 rounded-xl focus:ring-2 focus:ring-blue-500 focus:outline-none transition" required>
                            </div>
                            <div>
                                <label class="text-xs font-bold text-gray-400 uppercase mb-1 block">Họ tên người ứng tuyển</label>
                                <input type="text" name="applicantName" placeholder="Tên người ứng tuyển" class="w-full border-gray-200 border p-3 rounded-xl focus:ring-2 focus:ring-blue-500 focus:outline-none transition">
                            </div>
                            <div>
                                <label class="text-xs font-bold text-gray-400 uppercase mb-1 block">Số điện thoại</label>
                                <input type="text" name="phone" placeholder="Số điện thoại" class="w-full border-gray-200 border p-3 rounded-xl focus:ring-2 focus:ring-blue-500 focus:outline-none transition">
                            </div>
                            <div>
                                <label class="text-xs font-bold text-gray-400 uppercase mb-1 block">Địa chỉ</label>
                                <input type="text" name="address" placeholder="Địa chỉ người ứng tuyển" class="w-full border-gray-200 border p-3 rounded-xl focus:ring-2 focus:ring-blue-500 focus:outline-none transition">
                            </div>

                            <button class="w-full bg-gray-900 hover:bg-black text-white font-bold py-3 rounded-xl transition-all shadow-lg active:scale-95">
                                <i class="fas fa-paper-plane mr-2"></i> Lưu Công Việc
                            </button>
                        </form>
                    </div>
                </div>

                <div class="lg:col-span-2">
                    <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
                        <div class="p-6 border-b border-gray-50 flex justify-between items-center">
                            <h3 class="text-lg font-bold">Danh sách đã ứng tuyển</h3>
                            <span class="bg-blue-50 text-blue-600 text-xs font-bold px-3 py-1 rounded-full"><%= jobs.length %> Công việc</span>
                        </div>
                        
                        <div class="overflow-x-auto">
                            <table class="w-full text-left border-collapse">
                                <thead class="bg-gray-50">
                                    <tr>
                                        <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase">Ứng viên & Công việc</th>
                                        <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase">Liên hệ</th>
                                        <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase text-center">Trạng thái</th>
                                        <th class="px-6 py-4 text-xs font-bold text-gray-400 uppercase text-right">Thao tác</th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-gray-100">
                                    <% if (jobs.length === 0) { %>
                                        <tr>
                                            <td colspan="4" class="px-6 py-12 text-center text-gray-400">
                                                <i class="fas fa-folder-open text-4xl mb-3 block"></i>
                                                Chưa có dữ liệu nào được thêm.
                                            </td>
                                        </tr>
                                    <% } %>
                                    <% jobs.forEach(job => { %>
                                        <tr class="hover:bg-blue-50/30 transition border-b border-gray-100">
                                            <td class="px-6 py-4">
                                                <div class="text-blue-600 font-extrabold text-base uppercase leading-tight">
                                                    <%= job.applicantName || 'ẨN DANH' %>
                                                </div>
                                                <div class="font-bold text-gray-800 text-sm mt-0.5 tracking-tight">
                                                    <%= job.title %>
                                                </div>
                                                <div class="text-[11px] text-gray-400 font-medium italic mt-1 flex items-center gap-1">
                                                    <i class="far fa-building opacity-50"></i> <%= job.company %>
                                                </div>
                                            </td>

                                            <td class="px-6 py-4">
                                                <div class="space-y-1.5">
                                                    <div class="flex items-center gap-2 text-sm font-bold text-gray-600">
                                                        <i class="fas fa-phone-alt text-[10px] text-gray-300"></i>
                                                        <%= job.phone || 'Chưa có SĐT' %>
                                                    </div>
                                                    <div class="flex items-center gap-2 text-xs font-semibold text-gray-400">
                                                        <i class="fas fa-map-marker-alt text-[10px] text-gray-300"></i>
                                                        <%= job.address || 'Chưa cập nhật địa chỉ' %>
                                                    </div>
                                                </div>
                                            </td>
                                            <td class="px-6 py-4 text-center">
                                                <form action="/jobs/update/<%= job._id %>" method="POST">
                                                    <select name="status" onchange="this.form.submit()" class="text-[10px] font-extrabold uppercase rounded-md px-2 py-1 cursor-pointer 
                                                        <%= job.status === 'Đã đậu' ? 'bg-green-100 text-green-600' : 
                                                           job.status === 'Từ chối' ? 'bg-red-100 text-red-600' : 
                                                           job.status === 'Phỏng vấn' ? 'bg-purple-100 text-purple-600' : 'bg-blue-100 text-blue-600' %>">
                                                        <option value="Đang chờ" <%= job.status === 'Đang chờ' ? 'selected' : '' %>>Đang chờ</option>
                                                        <option value="Phỏng vấn" <%= job.status === 'Phỏng vấn' ? 'selected' : '' %>>Phỏng vấn</option>
                                                        <option value="Đã đậu" <%= job.status === 'Đã đậu' ? 'selected' : '' %>>Đã đậu</option>
                                                        <option value="Từ chối" <%= job.status === 'Từ chối' ? 'selected' : '' %>>Từ chối</option>
                                                    </select>
                                                </form>
                                            </td>
                                            <td class="px-6 py-4 text-right">
                                                <div class="flex justify-end gap-2">
                                                    <button onclick="openEditModal('<%= job._id %>', '<%= job.title %>', '<%= job.company %>', '<%= job.applicantName %>', '<%= job.phone %>', '<%= job.address %>')" class="text-gray-400 hover:text-blue-500 transition px-2">
                                                        <i class="fas fa-edit"></i>
                                                    </button>
                                                    <form action="/jobs/delete/<%= job._id %>" method="POST" onsubmit="return confirm('Bạn có chắc chắn muốn xóa công việc này?')">
                                                        <button type="submit" class="text-gray-400 hover:text-red-500 transition px-2">
                                                            <i class="fas fa-trash"></i>
                                                        </button>
                                                    </form>
                                                </div>
                                            </td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                            <% if (pages > 0) { %>
    <div class="p-6 border-t border-gray-50 flex justify-center items-center gap-2">
        
        <% if (currentPage == 1) { %>
            <span class="px-4 py-2 text-gray-300 cursor-not-allowed text-sm font-bold">« Trước</span>
        <% } else { %>
            <a href="/?page=<%= currentPage - 1 %>" class="px-4 py-2 text-blue-600 hover:bg-blue-50 rounded-lg text-sm font-bold transition">« Trước</a>
        <% } %>

        <div class="flex gap-1">
            <% for (let i = 1; i <= pages; i++) { %>
                <a href="/?page=<%= i %>" 
                   class="w-10 h-10 flex items-center justify-center rounded-lg text-sm font-bold transition
                   <%= i == currentPage ? 'bg-blue-600 text-white shadow-lg' : 'text-gray-600 hover:bg-gray-100' %>">
                    <%= i %>
                </a>
            <% } %>
        </div>

        <% if (currentPage == pages) { %>
            <span class="px-4 py-2 text-gray-300 cursor-not-allowed text-sm font-bold">Sau »</span>
        <% } else { %>
            <a href="/?page=<%= parseInt(currentPage) + 1 %>" class="px-4 py-2 text-blue-600 hover:bg-blue-50 rounded-lg text-sm font-bold transition">Sau »</a>
        <% } %>

    </div>
<% } %>
                        </div>
                    </div>
                </div>

            </div>
        <% } %>
    </main>

    <div id="editModal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50 p-4">
        <div class="bg-white p-8 rounded-2xl shadow-2xl w-full max-w-md">
            <h3 class="text-xl font-bold mb-6 text-gray-800">Chỉnh sửa thông tin</h3>
            <form id="editForm" method="POST" class="space-y-4">
                <input type="text" id="editTitle" name="title" placeholder="Vị trí" class="w-full border-gray-200 border p-3 rounded-xl outline-none">
                <input type="text" id="editCompany" name="company" placeholder="Công ty" class="w-full border-gray-200 border p-3 rounded-xl outline-none">
                <input type="text" id="editApplicantName" name="applicantName" placeholder="Họ tên" class="w-full border-gray-200 border p-3 rounded-xl outline-none">
                <input type="text" id="editPhone" name="phone" placeholder="SĐT" class="w-full border-gray-200 border p-3 rounded-xl outline-none">
                <input type="text" id="editAddress" name="address" placeholder="Địa chỉ" class="w-full border-gray-200 border p-3 rounded-xl outline-none">
                <div class="flex gap-3 mt-6">
                    <button type="button" onclick="closeEditModal()" class="flex-1 bg-gray-100 py-3 rounded-xl font-bold">Hủy</button>
                    <button type="submit" class="flex-1 bg-blue-600 text-white py-3 rounded-xl font-bold">Cập nhật</button>
                </div>
            </form>
        </div>
    </div>

    <script>
        function showRegister() {
            document.getElementById('login-form').classList.add('hidden');
            document.getElementById('register-form').classList.remove('hidden');
        }
        function showLogin() {
            document.getElementById('register-form').classList.add('hidden');
            document.getElementById('login-form').classList.remove('hidden');
        }

        // HÀM ĐIỀU KHIỂN MODAL
        function openEditModal(id, title, company, name, phone, address) {
            document.getElementById('editForm').action = '/jobs/update-info/' + id;
            document.getElementById('editTitle').value = title;
            document.getElementById('editCompany').value = company;
            document.getElementById('editApplicantName').value = name;
            document.getElementById('editPhone').value = phone;
            document.getElementById('editAddress').value = address;
            document.getElementById('editModal').classList.remove('hidden');
        }
        function closeEditModal() {
            document.getElementById('editModal').classList.add('hidden');
        }
    </script>
</body>
</html>